{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build:cf": {
      "inputs": ["$TURBO_DEFAULT$", "!.env", "!.env.*"],
      "outputs": [".next/**", "!.next/cache/**", ".open-next/**"]
    },
    "dev:web": {
      "cache": false,
      "persistent": true
    },
    "dev:typecheck": {
      "cache": false,
      "persistent": true
    }
  }
}
